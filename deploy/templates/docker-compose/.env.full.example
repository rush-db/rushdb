# RushDB full self-hosted stack — environment.
# Copy to `.env` (or run ./install.sh to generate one with strong secrets):
#   cp .env.full.example .env
#
# The compose file has working defaults so it starts without this file, but you
# MUST set real secrets before exposing the instance to a network.

# --- Dashboard / API ---
RUSHDB_PORT=3000
RUSHDB_LOGIN=admin
RUSHDB_PASSWORD=change-me
# Exactly 32 characters. Generate with: openssl rand -hex 16
RUSHDB_AES_256_ENCRYPTION_KEY=change-me-to-a-32-character-key
RUSHDB_DASHBOARD_URL=http://localhost:3000
RUSHDB_BASE_URL=http://localhost:3000

# --- Bundled Neo4j (managed by this Compose project) ---
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-neo4j

# --- Bundled Postgres (RushDB metadata) ---
POSTGRES_DB=rushdb
POSTGRES_USER=rushdb
POSTGRES_PASSWORD=change-me-postgres

# --- Pin images for reproducible deploys (recommended over :latest) ---
# RUSHDB_IMAGE_TAG=latest
# NEO4J_IMAGE_TAG=2026.01.4

# --- Optional OpenAI-compatible AI providers ---
# Enable vector search and relationship analysis. Leave blank to disable.
# RUSHDB_LLM_BASE_URL=https://openrouter.ai/api/v1
# RUSHDB_LLM_API_KEY=
# RUSHDB_LLM_MODEL=openai/gpt-5.6-luna
# RUSHDB_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# RUSHDB_EMBEDDING_API_KEY=
# RUSHDB_EMBEDDING_MODEL=openai/text-embedding-3-small
# RUSHDB_EMBEDDING_DIMENSIONS=1024
