RUSHDB_PORT=3000
RUSHDB_LOGIN=admin
RUSHDB_PASSWORD=change-me
RUSHDB_AES_256_ENCRYPTION_KEY=32SymbolStringForTokenEncryption
RUSHDB_DASHBOARD_URL=http://localhost:3000
RUSHDB_BASE_URL=http://localhost:3000

# Required external Neo4j or Aura connection. Neo4j is intentionally not managed by this Compose project.
NEO4J_URL=neo4j+s://your-aura-host.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-neo4j

POSTGRES_DB=rushdb
POSTGRES_USER=rushdb
POSTGRES_PASSWORD=change-me-postgres

# Optional OpenAI-compatible providers.
RUSHDB_LLM_BASE_URL=https://openrouter.ai/api/v1
RUSHDB_LLM_API_KEY=
RUSHDB_LLM_MODEL=google/gemini-2.5-flash-lite

RUSHDB_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
RUSHDB_EMBEDDING_API_KEY=
RUSHDB_EMBEDDING_MODEL=openai/text-embedding-3-small
RUSHDB_EMBEDDING_DIMENSIONS=1024
