{
  "name": "@rushdb/javascript-sdk",
  "description": "RushDB JavaScript SDK — memory layer for AI agents and modern apps",
  "keywords": [
    "rushdb",
    "database",
    "graph database",
    "graph-database",
    "ai memory",
    "ai-memory",
    "agent memory",
    "agent-memory",
    "memory layer",
    "memory-layer",
    "ai agents",
    "ai-agents",
    "llm memory",
    "llm-memory",
    "mcp",
    "vector search",
    "vector-search",
    "rag",
    "embedding",
    "embeddings",
    "knowledge graph",
    "knowledge-graph",
    "json normalization",
    "json-normalization",
    "schema-less",
    "schemaless",
    "no-schema",
    "self-hosted",
    "rest api",
    "rest-api",
    "graph",
    "relationships",
    "persistence",
    "rush-db"
  ],
  "license": "Apache-2.0",
  "version": "2.3.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.worker.d.ts",
  "scripts": {
    "build": "pnpm clean && pnpm build:package && pnpm build:types",
    "build:package": "node esbuild.config.cjs",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "types:check": "tsc --noEmit",
    "clean": "rm -rf ./dist ./node_modules/.cache ./coverage ./esm ./cjs ./types",
    "flush": "rm -rf node_modules",
    "lint:circularDeps": "madge --circular ./src/*",
    "lint:circularDepsWithImage": "madge --image graph.svg --circular ./src/*"
  },
  "devDependencies": {
    "dotenv": "^16.0.3"
  },
  "peerDependencies": {},
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "bugs": "https://github.com/rush-db/rushdb/issues",
  "repository": {
    "type": "https",
    "url": "https://github.com/rush-db/rushdb"
  }
}
