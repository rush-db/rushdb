{
  "name": "rushdb-dashboard",
  "version": "2.10.2",
  "description": "RushDB Dashboard",
  "type": "module",
  "private": true,
  "license": "Elastic License 2.0",
  "scripts": {
    "dev": "pnpm theme:generate && NODE_ENV=development vite",
    "build": "pnpm theme:generate && pnpm types:check && NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "theme:generate": "tsx config/generate-theme.ts",
    "preview": "vite preview",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "pnpm lint --fix",
    "types:check": "tsc --noEmit",
    "reinstall": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && pnpm i"
  },
  "dependencies": {
    "@floating-ui/react-dom": "^2.0.2",
    "@hookform/resolvers": "^3.1.0",
    "@monaco-editor/react": "^4.5.2",
    "@nanostores/logger": "0.2.3",
    "@nanostores/persistent": "0.9.1",
    "@nanostores/react": "0.7.1",
    "@nanostores/router": "0.11.0",
    "@number-flow/react": "^0.5.10",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "2.1.5",
    "@radix-ui/react-hover-card": "^1.1.2",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@rushdb/javascript-sdk": "workspace:*",
    "@sentry/react": "7.74.0",
    "@stripe/stripe-js": "^2.4.0",
    "@tanstack/react-query": "^5.84.1",
    "@tsparticles/confetti": "^4.1.3",
    "class-variance-authority": "^0.5.2",
    "clsx": "^2.1.1",
    "cmdk": "^0.2.0",
    "date-fns": "^2.30.0",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.52.0",
    "nanoid": "^5.0.9",
    "nanostores": "^0.9.3",
    "react": "19.1.0",
    "react-cool-virtual": "^0.7.0",
    "react-day-picker": "^8.8.2",
    "react-dom": "19.1.0",
    "react-force-graph": "^1.45.4",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "~7.41.0",
    "react-joyride": "^2.9.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "three": "^0.171.0",
    "three-spritetext": "^1.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@fontsource/jetbrains-mono": "5.0.18",
    "@tailwindcss/vite": "^4.3.2",
    "@fontsource/manrope": "5.0.18",
    "@types/culori": "^2.0.0",
    "@types/node": "^18.15.11",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@types/react-window": "^1.8.5",
    "@types/three": "^0.171.0",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitejs/plugin-react-swc": "^3.3.0",
    "culori": "^3.1.3",
    "eslint": "9.2.0",
    "eslint-plugin-import": "^2.29.1",
    "framer-motion": "^10.12.20",
    "nanoevents": "^8.0.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "5.7.2",
    "vite": "8.0.16",
    "vite-plugin-checker": "^0.6.4",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
