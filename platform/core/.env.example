RUSHDB_PORT=3000
# The port on which the application server will listen for incoming requests.

RUSHDB_AES_256_ENCRYPTION_KEY=32SymbolStringForTokenEncryption
# The encryption key for securing API tokens using AES-256 encryption.
# It must be exactly 32 characters long to meet the 256-bit key length requirement.

# Optional (recommended for MCP OAuth in production): RS256 JWT signing keys.
# If provided, OAuth tokens are signed with RS256 and exposed via /.well-known/jwks.json.
# Prefer *_BASE64 values in CI/containers to avoid multiline PEM escaping issues.
# RUSHDB_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# RUSHDB_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# RUSHDB_JWT_PRIVATE_KEY_BASE64=
# RUSHDB_JWT_PUBLIC_KEY_BASE64=
# RUSHDB_JWT_KID=rushdb-mcp-rs256

RUSHDB_DASHBOARD_URL=http://localhost:3005
# The URL of the RushDB dashboard. This is used for accessing the management interface.

RUSHDB_BASE_URL=http://localhost:3000
# Public/base URL of this RushDB API. The connector control plane passes this to synx workers as the RushDB destination URL.

RUSHDB_SERVE_STATIC=false
# A flag to enable or disable serving static files. Set to 'true' to serve static assets (e.g., public folder) via the application; otherwise, set to 'false'.

RUSHDB_SELF_HOSTED=true
# Indicates whether RushDB is running in self-hosted mode (true) or in a managed environment (false).

RUSHDB_LOGIN=admin
# The login username for the RushDB admin account.

RUSHDB_PASSWORD=password
# The password for the RushDB admin account. Change this to a secure value in production.

# RUSHDB_ALLOWED_LOGINS=[]
# An optional find of allowed login usernames for RushDB. If empty, all logins are allowed.

# RATE_LIMITER_REQUESTS_LIMIT=10
# Maximum number of requests allowed within a specific time frame to prevent abuse.

# RATE_LIMITER_TTL=1000
# Time-to-live (TTL) for the rate limiter, defining the time frame for the request limit.

# Auth & captcha
# GOOGLE_CLIENT_ID=
# The client ID for Google OAuth integration. Required for enabling Google login.

# GOOGLE_SECRET=
# The client secret for Google OAuth integration. Must match the client ID.

# GH_CLIENT_ID=
# The client ID for GitHub OAuth integration. Used for enabling GitHub login.

# GH_SECRET=
# The client secret for GitHub OAuth integration. Corresponds to the GitHub client ID.

# SERVICE_CAPTCHA_KEY=
# The private key for the CAPTCHA service used on the server side for verification.

# Enterprise SSO (SAML 2.0 / OIDC)
# No global IdP credentials are required: each workspace configures its own
# identity provider from Dashboard → Workspace Settings → Single Sign-On.
# The OIDC client secret is encrypted at rest with RUSHDB_AES_256_ENCRYPTION_KEY,
# and the service-provider URLs handed to customer IT (ACS, Entity ID, metadata,
# OIDC redirect URI) are derived from RUSHDB_BASE_URL — make sure it is the
# publicly reachable API origin (e.g. https://api.rushdb.com).

# Mailer
# MAIL_HOST=
# The host address for the email service provider (e.g., smtp.gmail.com).

# MAIL_USER=
# The username for authenticating with the email service.

# MAIL_PASSWORD=
# The password for authenticating with the email service.

# MAIL_FROM=
# The default "from" email address used for outgoing emails.

# Billing Service
# BILLING_SERVICE_URL=
# URL of the external billing service. Leave unset to disable billing enforcement.

# RUSHDB_BILLING_SECRET=
# Shared secret used to authenticate requests from the platform to the billing service.

# Synx managed connectors
# RUSHDB_SYNX_CONTROL_TOKEN=
# Shared internal token used by synx workers when calling /api/v1/connectors/_internal/*.
# Required only when running managed connector workers.

# RUSHDB_SYNX_DESTINATION_API_KEY=
# Internal write API key that synx uses to write into RushDB projects.
# Temporary bootstrap option for managed synx; prefer per-project connector tokens in production.

# NEO4J_URL=bolt://localhost:7687
# The URL for connecting to the Neo4j database instance.

# NEO4J_USERNAME=neo4j
# The username for authenticating with the Neo4j database.

# NEO4J_PASSWORD=password
# The password for authenticating with the Neo4j database. Change this to a secure value in production.

# NEO4J_TRANSACTION_TIMEOUT_MS=55000
# Server-side time budget (ms) for a single Neo4j transaction; Neo4j rolls the transaction
# back when exceeded and the API returns 408. Defaults to 55000 — just under the 60s gateway
# limit on managed deployments. Self-hosted setups without a gateway may raise this.

# RUSHDB_MAX_TRAVERSAL_HOPS=10
# Ceiling for variable-length traversal depth (`$relation.hops` in SearchQuery). Defaults to 25.
# Only enforced on the shared default Neo4j connection: self-hosted deployments
# (RUSHDB_SELF_HOSTED=true) and projects with a custom external Neo4j allow unbounded hops,
# guarded by NEO4J_TRANSACTION_TIMEOUT_MS.

# SQL Database (dashboard entities: users, workspaces, projects, tokens, OAuth)
SQL_DB_TYPE=sqlite
# The SQL database type. Use 'sqlite' (default for self-hosted) or 'postgres' (for cloud deployments).

# SQL_DB_PATH=./rushdb.db
# Path to the SQLite database file. Only used when SQL_DB_TYPE=sqlite.

# SQL_DB_URL=postgresql://user:password@localhost:5432/rushdb
# PostgreSQL connection URL. Only used when SQL_DB_TYPE=postgres.

# Embedding (vector indexes)
# RUSHDB_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# Base URL of the OpenAI-compatible embeddings endpoint.
# Defaults to https://api.openai.com/v1 when omitted.
# Set to https://openrouter.ai/api/v1 for OpenRouter,
# or any other compatible provider (Azure OpenAI, Ollama, etc.).

# RUSHDB_EMBEDDING_API_KEY=sk-or-v1-...
# API key (Bearer token) for the embedding provider.

# RUSHDB_EMBEDDING_MODEL=openai/text-embedding-3-small
# The embedding model identifier passed to your provider.
# Examples: text-embedding-3-small (OpenAI direct), openai/text-embedding-3-small (OpenRouter).
# Query-time semantic search embeds the user's query on the request path, so pick a
# model/provider with consistent sub-second latency.
# When set, embedding index policies become available and the Indexes tab is shown in the dashboard.
# Omit this variable to disable embedding indexes entirely.
# Changing the model later invalidates already-stored vectors (different models produce
# incompatible embedding spaces, even at identical dimensions). The server detects this
# at startup and automatically strips old vectors and queues every managed index for
# re-embedding with the new model — no manual step needed on deploy.

# RUSHDB_EMBEDDING_DIMENSIONS=1024
# The number of dimensions produced by the embedding model above.
# Must match the model/provider output dimensions.

# RUSHDB_EMBEDDING_BATCH_SIZE=500
# Number of property VALUE relationships to embed per backfill batch (default: 500).

# RUSHDB_EMBEDDING_MAX_RUNTIME_MS=50000
# Maximum wall-clock ms the backfill scheduler spends on a single embedding index per tick (default: 50000).

# Relationship suggestions (OpenAI-compatible chat completions)
# RUSHDB_LLM_BASE_URL=https://api.openai.com/v1
# Base URL of the OpenAI-compatible chat completions endpoint.

# RUSHDB_LLM_API_KEY=sk-...
# API key (Bearer token) for relationship pattern suggestions.

# RUSHDB_LLM_MODEL=gpt-5.6-luna
# Chat model identifier used for AI search query generation and relationship suggestions.
# Examples: gpt-5.6-luna (OpenAI direct), openai/gpt-5.6-luna (OpenRouter).

# --- Pagination ---

# RUSHDB_PAGINATION_DEFAULT_LIMIT=100
# Default page size when `limit` is not specified in a search query.

# RUSHDB_PAGINATION_MAX_LIMIT=1000
# Maximum allowed `limit` value. Requests above this are clamped.
